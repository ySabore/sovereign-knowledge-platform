# Copy to .env — never commit secrets

ENVIRONMENT=development

# Optional: OpenAPI labels
API_TITLE=Sovereign Knowledge Platform API
API_VERSION=0.2.0
EXPOSE_PUBLIC_CONFIG=true

DATABASE_URL=postgresql+psycopg://skp:skp@127.0.0.1:5433/skp
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DATABASE_ECHO=false

# Local Redis or Upstash: use rediss:// for TLS (recommended for Upstash).
REDIS_URL=redis://127.0.0.1:6380/0
REDIS_SOCKET_TIMEOUT_SECONDS=2.0

# Org plan tiers (stored on `organizations.plan`): free_trial | starter | team | business | admin
# Tiered query/sync limits use Redis when enabled below.

# RBAC: simple = workspace-wide access for members; full = per-document ACL via `document_permissions`
RBAC_MODE=simple

# If set (comma-separated org slugs), platform owners only see those organizations in GET /organizations/me
# (org picker + Platform overview). Leave empty to list every org in the database. Example: sterling-vale-llp
PLATFORM_OWNER_VISIBLE_ORG_SLUGS=

# When true, Redis applies per-org plan limits on chat/search, connector sync, and admin API routes
RATE_LIMIT_REDIS_ENABLED=true

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ISSUER=sovereign-knowledge-platform
# Email/password login only (HS256). Clerk sessions ignore this — their JWT lifetime is set in Clerk Dashboard.
# Raise for fewer re-logins during long demos (max 10080 = 7 days).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Nango (optional — OAuth proxy for Confluence, Drive, Notion, GitHub, Jira).
# 1) Create a Nango account → Integrations → enable Google Drive (integration id is usually `google-drive`).
# 2) Add Google OAuth client id/secret in Nango; set callback URL Nango shows you.
# 3) Put the Secret Key here (server) and Public Key below (exposed to the SPA via GET /config/public).
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_HOST=https://api.nango.dev

# Stripe (optional — Checkout, Portal, webhooks). Create Products/Prices in Dashboard ($49/$149/$299/$599/mo).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Map each Price id (price_…) to internal plan: starter | team | business | scale
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_SCALE=

# Optional Clerk (set CLERK_ENABLED=true and issuer from Clerk Dashboard → API keys → Frontend API URL)
CLERK_ENABLED=true
# Example: https://your-app.clerk.accounts.dev
CLERK_ISSUER=https://relieved-macaw-64.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_JWKS_URL=https://relieved-macaw-64.clerk.accounts.dev/.well-known/jwks.json
# Same value as CLERK_PUBLISHABLE_KEY; required for `npm run dev`. For Docker `web` image, compose passes this as a build arg so the bundle includes Clerk.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Only if you use a named JWT template with a fixed audience
CLERK_AUDIENCE=
# Seconds of clock skew tolerance for Clerk JWT iat/nbf/exp (raise if Docker time drifts; default 120)
CLERK_JWT_LEEWAY_SECONDS=120
# Clerk: Dashboard → Sessions — session length and the *session JWT* `exp` (often ~60s per token) are controlled there.
# If the SPA feels like it “expires quickly”, lengthen session lifetime or JWT template TTL in Clerk; the frontend refreshes on a fraction of that TTL.
# Dashboard → Sessions → Customize session token → Claims (JSON). Default JWT has no email.
# Add either:
#   { "email": "{{user.primary_email_address}}" }
# or (Clerk doc naming):
#   { "primaryEmail": "{{user.primary_email_address}}" }
# Save, then sign out and sign in again so a new session token is issued.

# CORS: comma-separated origins (include http://localhost:8080 when using the docker `web` service on port 8080).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Trusted hosts (optional): comma-separated Host header allowlist; leave empty to disable.
# TRUSTED_HOSTS=api.example.com,localhost

LOG_LEVEL=INFO
LOG_JSON=false

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

DOCUMENT_STORAGE_ROOT=./data/documents
MAX_UPLOAD_SIZE_MB=50
INGESTION_CHUNK_SIZE=1200
INGESTION_CHUNK_OVERLAP=200
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
EMBEDDING_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Seconds for Ollama embed + /api/generate. Tune with: python scripts/benchmark_ollama.py --prompt-mode long
OLLAMA_HTTP_TIMEOUT_SECONDS=60
OLLAMA_KEEP_ALIVE=30m

RETRIEVAL_TOP_K=5
# Pull this many vector hits before heuristic rerank (no extra models); should be >= RETRIEVAL_TOP_K.
RETRIEVAL_CANDIDATE_K=12
# RAG heuristic rerank: none | lexical_blend | lexical_mmr
RAG_RERANK_MODE=lexical_mmr
RAG_LEXICAL_WEIGHT=0.25
RAG_MMR_LAMBDA=0.7
CHAT_MIN_CITATION_SCORE=0.30
CHAT_LEXICAL_OVERLAP_MIN=0.10
CHAT_CITATION_QUOTE_MAX_CHARS=400
ANSWER_GENERATION_PROVIDER=extractive
ANSWER_GENERATION_MODEL=llama3.2
ANSWER_GENERATION_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Per-organization overrides: PATCH /organizations/{id} with preferred_chat_provider (extractive|ollama|openai|anthropic)
# and preferred_chat_model. Platform owner can also PATCH encrypted per-org keys (requires ORG_LLM_FERNET_KEY).
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ORG_LLM_FERNET_KEY=
# Optional platform-wide fallbacks when an org has no stored key (org-specific keys take precedence).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
ANTHROPIC_API_BASE=https://api.anthropic.com
OPENAI_DEFAULT_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_CHAT_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_API_VERSION=2023-06-01
CLOUD_LLM_HTTP_TIMEOUT_SECONDS=120

# Dev seed (scripts/seed.py)
SEED_PLATFORM_OWNER_EMAIL=owner@example.com
SEED_PLATFORM_OWNER_PASSWORD=ChangeMeNow!
# Clerk users start without platform owner; after first sign-in run:
#   PROMOTE_PLATFORM_OWNER_EMAIL=you@company.com python scripts/promote_platform_owner.py
# (or docker compose exec -e PROMOTE_PLATFORM_OWNER_EMAIL=… api python scripts/promote_platform_owner.py)

# Demo users + roles seed (scripts/seed_demo_users.py)
# Attaches demo accounts to the Sterling & Vale org (same slug as scripts/seed_law_firm.py).
SEED_DEMO_USERS=false
RESET_DEMO_PASSWORDS=false
DEMO_ORG_NAME=Sterling & Vale LLP
DEMO_ORG_SLUG=sterling-vale-llp
DEMO_WORKSPACE_NAME=Pilot Workspace

ORG_ADMIN_EMAIL=org-admin@example.com
ORG_ADMIN_PASSWORD=ChangeMeNow!
WORKSPACE_ADMIN_EMAIL=ws-admin@example.com
WORKSPACE_ADMIN_PASSWORD=ChangeMeNow!
ORG_MEMBER_EMAIL=org-member@example.com
ORG_MEMBER_PASSWORD=ChangeMeNow!
WORKSPACE_MEMBER_EMAIL=ws-member@example.com
WORKSPACE_MEMBER_PASSWORD=ChangeMeNow!

# Law firm sample org (scripts/seed_law_firm.py) — idempotent by org slug
# SEED_LAW_FIRM=true python scripts/seed_law_firm.py
# docker compose exec -e SEED_LAW_FIRM=true api python scripts/seed_law_firm.py
SEED_LAW_FIRM=false
#LAW_FIRM_ORG_NAME=Sterling & Vale LLP
#LAW_FIRM_ORG_SLUG=sterling-vale-llp
#LAW_FIRM_ASSOCIATE_EMAIL=morgan.lee@sterlingvale.demo
#LAW_FIRM_ASSOCIATE_PASSWORD=DemoLaw2026!
#LAW_FIRM_ASSOCIATE_NAME=Morgan Lee

# Law firm RAG demo: generates PDFs, embeddings, sample questions (needs Ollama + embedding model)
# SEED_LAW_FIRM_RAG=true python scripts/seed_law_firm_rag.py
SEED_LAW_FIRM_RAG=false

# Remove every org except Sterling (destructive; needs DATABASE_URL). Default keep slug:
# sterling-vale-llp, or set KEEP_ORGANIZATION_NAME="Sterling & Vale LLP" if slug differs.
# PRUNE_ORGANIZATIONS=true python scripts/prune_organizations_keep_slug.py
